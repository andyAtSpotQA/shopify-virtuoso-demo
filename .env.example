# Copy to .env and fill in from the Shopify Partner dashboard:
#   App distribution > <your app> > Dev Dashboard > Settings > Credentials
# Both values are issued per-app, not per-store.

SHOPIFY_API_KEY=your_client_id_here
SHOPIFY_API_SECRET=your_client_secret_here

# Scopes to request when minting a token (comma-separated).
# Must be a subset of the scopes configured in the Partner dashboard.
# Default: read_products
# SHOPIFY_SCOPES=read_products,write_products

# Optional: the port the callback server listens on.
# Must match the Redirect URL configured in the Partner dashboard.
# Default: 4000
# PORT=4000
